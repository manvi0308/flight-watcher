# ── Twilio (WhatsApp) ──────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=   # Twilio sandbox number
WHATSAPP_TO=          # your WhatsApp number

# ── SerpAPI ────────────────────────────────────────────────────
SERPAPI_KEY=

# ── Flight Config ──────────────────────────────────────────────
FLIGHT_ORIGIN=BLR        # IATA code e.g. BOM, DEL, BLR
FLIGHT_DESTINATION=DEL   # IATA code e.g. DXB, LHR, SIN
FLIGHT_DATE=2026-05-01   # YYYY-MM-DD
CURRENCY=INR
PRICE_THRESHOLD=7500    # alert when price drops below this

# ── Polling ────────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=3600   # 600 = every 10 minutes
